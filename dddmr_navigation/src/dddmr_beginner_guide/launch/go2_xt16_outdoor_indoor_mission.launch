<launch>
  <arg name="config_file" default="$(find-pkg-share dddmr_beginner_guide)/config/go2_xt16_navigation.yaml"/>
  <arg name="map_config_file" default="$(var config_file)"/>
  <arg name="relocalization_config_file" default="$(find-pkg-share dddmr_beginner_guide)/config/go2_xt16_relocalization.yaml"/>
  <arg name="route_config_file" default="$(find-pkg-share dddmr_route_navigation)/config/go2_xt16_recorded_route.yaml"/>
  <arg name="mission_config_file" default="$(find-pkg-share dddmr_route_navigation)/config/go2_xt16_outdoor_indoor_mission.yaml"/>
  <arg name="mission_map_directory" default="/root/dddmr_bags/go2_xt16_mouth_mapping_20260722_132433_map_2026_07_22_05_24_32"/>
  <arg name="route_directory" default="/root/dddmr_bags/routes"/>
  <arg name="rviz" default="true"/>
  <arg name="rviz_config" default="$(find-pkg-share dddmr_beginner_guide)/rviz/go2_xt16_navigation.rviz"/>

  <arg name="publish_static_tf" default="true"/>
  <arg name="standardize_odom" default="true"/>
  <arg name="raw_odom_topic" default="/utlidar/robot_odom"/>
  <arg name="odom_topic" default="/dddmr_go2/robot_odom_standard"/>
  <arg name="lidar_topic" default="/lidar_points"/>
  <arg name="odom_sync_enabled" default="true"/>
  <arg name="odom_sync_tolerance_sec" default="0.05"/>
  <arg name="odom_sync_wait_timeout_sec" default="0.1"/>
  <arg name="odom_time_offset_sec" default="0.0"/>
  <arg name="local_lidar_expected_sensor_time_sec" default="0.35"/>
  <arg name="start_sport_dry_run_adapter" default="true"/>

  <!-- Start one shared map/localization chain, but no legacy P2P process. -->
  <include file="$(find-pkg-share dddmr_beginner_guide)/launch/go2_xt16_navigation.launch">
    <arg name="config_file" value="$(var config_file)"/>
    <arg name="map_config_file" value="$(var map_config_file)"/>
    <arg name="relocalization_config_file" value="$(var relocalization_config_file)"/>
    <arg name="rviz" value="$(var rviz)"/>
    <arg name="rviz_config" value="$(var rviz_config)"/>
    <arg name="start_move_base" value="false"/>
    <arg name="publish_static_tf" value="$(var publish_static_tf)"/>
    <arg name="standardize_odom" value="$(var standardize_odom)"/>
    <arg name="raw_odom_topic" value="$(var raw_odom_topic)"/>
    <arg name="odom_topic" value="$(var odom_topic)"/>
    <arg name="lidar_topic" value="$(var lidar_topic)"/>
    <arg name="odom_sync_enabled" value="$(var odom_sync_enabled)"/>
    <arg name="odom_sync_tolerance_sec" value="$(var odom_sync_tolerance_sec)"/>
    <arg name="odom_sync_wait_timeout_sec" value="$(var odom_sync_wait_timeout_sec)"/>
    <arg name="odom_time_offset_sec" value="$(var odom_time_offset_sec)"/>
    <arg name="local_lidar_expected_sensor_time_sec" value="$(var local_lidar_expected_sensor_time_sec)"/>
    <arg name="start_go2_nav_cmd_gate" value="true"/>
    <arg name="go2_nav_cmd_gate_input_topic" value="/dddmr_go2/dry_run_cmd_vel"/>
    <arg name="start_sport_dry_run_adapter" value="$(var start_sport_dry_run_adapter)"/>
    <arg name="start_go2_sport_adapter" value="false"/>
    <arg name="go2_sport_enable_output" value="false"/>
    <arg name="go2_sport_allow_real_request_topic" value="false"/>
  </include>

  <node pkg="global_planner" exec="global_planner_node" output="screen" respawn="false">
    <param from="$(var config_file)"/>
    <param name="use_sim_time" value="false"/>
  </node>

  <!-- One process owns one local planner/perception instance shared by the
       route and P2P controllers. Their direct outputs remain isolated. -->
  <node pkg="dddmr_route_navigation" exec="outdoor_indoor_move_base_node"
        output="screen" respawn="false">
    <!-- Recovery behaviors still use the legacy relative cmd_vel name. Keep
         their output inside the indoor source selected by the mission mux. -->
    <remap from="/cmd_vel" to="/dddmr_go2/indoor_cmd_vel"/>
    <param from="$(var config_file)"/>
    <param from="$(var route_config_file)"/>
    <param from="$(var mission_config_file)"/>
    <param name="lidar.expected_sensor_time"
           value="$(var local_lidar_expected_sensor_time_sec)" type="float"/>
    <param name="use_sim_time" value="false"/>
  </node>

  <node pkg="dddmr_route_navigation" exec="go2_mission_cmd_mux.py"
        output="screen" respawn="false">
    <param from="$(var mission_config_file)"/>
    <param name="use_sim_time" value="false"/>
  </node>

  <node pkg="dddmr_route_navigation" exec="outdoor_indoor_mission.py"
        output="screen" respawn="false">
    <param from="$(var mission_config_file)"/>
    <param name="active_map_directory" value="$(var mission_map_directory)" type="str"/>
    <param name="route_directory" value="$(var route_directory)" type="str"/>
    <param name="odom_topic" value="$(var odom_topic)" type="str"/>
    <param name="use_sim_time" value="false"/>
  </node>
</launch>
