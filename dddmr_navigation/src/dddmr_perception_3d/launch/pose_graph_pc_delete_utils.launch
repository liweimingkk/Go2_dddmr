<?xml version="1.0"?>
<launch>
  <arg name="map_dir" description="Global feature/surface editor PCD"/>
  <arg name="ground_dir" description="Global ground reference PCD"/>
  <arg name="map_down_sample" default="0.10"/>
  <arg name="ground_down_sample" default="0.10"/>
  <arg
    name="rviz_config"
    default="$(find-pkg-share perception_3d)/rviz/pose_graph_pc_delete_utils.rviz"/>

  <node pkg="mcl_3dl" exec="pcl_publisher" output="screen" respawn="false">
    <param from="$(find-pkg-share mcl_3dl)/config/pcl_publisher.yaml"/>
    <param name="map_dir" value="$(var map_dir)"/>
    <param name="ground_dir" value="$(var ground_dir)"/>
    <param name="map_down_sample" value="$(var map_down_sample)"/>
    <param name="ground_down_sample" value="$(var ground_down_sample)"/>
  </node>

  <!-- The PCDs are already in map coordinates. Do not publish map TF while
       editing, so this utility cannot conflict with localization. -->
  <node
    name="rviz2_pose_graph_pc_delete"
    pkg="rviz2"
    exec="rviz2"
    args="-d $(var rviz_config)"/>
</launch>
